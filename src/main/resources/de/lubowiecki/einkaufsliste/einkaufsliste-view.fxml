    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
   <children>
      <TextField fx:id="eingabe" onKeyPressed="#add" prefHeight="25.0" prefWidth="310.0" />
      <ListView fx:id="ausgabe" prefHeight="283.0" prefWidth="210.0" />
   </children>
</VBox>
